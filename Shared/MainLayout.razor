@inherits LayoutComponentBase

<div id="app">
    <header class="top-bar">
        <a class="logo" href="" aria-label="Blazing Pizza home">
            <img src="img/logo.svg" alt="Blazing Pizza" />
        </a>
        <NavLink href="" class="nav-tab" Match="NavLinkMatch.All">
            <img src="img/pizza-slice.svg" alt="" />
            <div>Get Pizza</div>
        </NavLink>
        <NavLink href="myorders" class="nav-tab">
            <img src="img/bike.svg" alt="" />
            <div>My Orders</div>
        </NavLink>
    </header>

    <div class="content">
        @Body
    </div>

    <footer>
        &copy; Blazing Pizza @DateTime.UtcNow.Year &mdash; @AppBranding.StudentName, @AppBranding.Country
    </footer>
</div>

